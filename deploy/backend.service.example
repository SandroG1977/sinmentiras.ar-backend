[Unit]
Description=sinmentiras.ar backend (FastAPI)
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/sinmentiras/backend
EnvironmentFile=/opt/sinmentiras/backend/.env
ExecStart=/opt/sinmentiras/backend/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target

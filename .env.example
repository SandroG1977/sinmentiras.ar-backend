APP_NAME=sinmentiras.ar backend
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_QUERY_MODEL=gpt-4o-mini
OPENAI_RESPONSE_TEMPERATURE=0.1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
RAG_ENABLED=true
RAG_TOP_K=5
RAG_REWRITER_ENABLED=true
RAG_HYDE_ENABLED=true
RAG_KNOWLEDGE_PATHS=app/knowledge
RAG_DB_PATH=app/data/rag.sqlite3
RAG_USE_FAISS=true
RAG_POSTGRES_DSN=
CACHE_ENABLED=true
CACHE_MIN_SIMILARITY=0.93
CACHE_SQLITE_PATH=app/data/cache.sqlite3
CACHE_POSTGRES_DSN=
CACHE_QUERY_CHUNKING_ENABLED=true
CACHE_QUERY_CHUNK_SIZE=240
CACHE_QUERY_CHUNK_OVERLAP=40
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
